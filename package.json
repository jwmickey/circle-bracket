{
  "name": "circle-bracket",
  "version": "1.0.0",
  "description": "Circular bracket for tournaments",
  "repository": "https://github.com/jwmickey/circle-bracket",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "start": "nodemon --watch \"webpack.*.js\" --exec \"webpack serve --mode development\"",
    "build": "webpack --mode production",
    "serve": "serve dist",
    "fetch-teams": "node bin/fetch-teams.js",
    "fetch-bracket": "node -r esm bin/fetch-ncaa-bracket.js",
    "fetch-sr-bracket": "node -r esm bin/fetch-sr-bracket.js",
    "update-logo": "node -r esm bin/update-logo.js",
    "preinstall": "npx npm-force-resolutions",
    "prettier": "npx prettier --write .",
    "lint": "npx eslint src/lib/**"
  },
  "resolutions": {
    "glob-parent": "6.0.2"
  },
  "author": "Jody Mickey <jody.mickey@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.21.0",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/preset-env": "^7.20.2",
    "@types/downloadjs": "^1.4.3",
    "@types/jest": "^27.4.1",
    "@typescript-eslint/eslint-plugin": "^5.14.0",
    "@typescript-eslint/parser": "^5.14.0",
    "babel-loader": "^9.1.2",
    "babel-minify-webpack-plugin": "^0.3.1",
    "babel-preset-stage-2": "^6.24.1",
    "cheerio": "^1.0.0-rc.5",
    "clean-webpack-plugin": "^2.0.2",
    "copy-webpack-plugin": "^10.2.4",
    "css-loader": "^2.1.1",
    "eslint": "^8.11.0",
    "eslint-plugin-vue": "^8.5.0",
    "fast-sass-loader": "^2.0.1",
    "file-loader": "^3.0.1",
    "html-webpack-plugin": "^5.5.0",
    "node-sass": "^8.0.0",
    "nodemon": "^2.0.21",
    "npm-force-resolutions": "^0.0.10",
    "jest": "^27.5.1",
    "prettier": "^2.5.1",
    "serve": "^14.2.0",
    "style-loader": "^1.3.0",
    "sass": "^1.49.9",
    "svgo": "^2.3.0",
    "terser-webpack-plugin": "^5.3.7",
    "ts-jest": "^27.1.3",
    "ts-loader": "^9.2.8",
    "url-loader": "^4.1.1",
    "webpack": "^5.76.1",
    "webpack-cli": "^5.0.1",
    "webpack-dev-server": "^4.11.1",
    "webpack-merge": "^5.8.0"
  },
  "dependencies": {
    "aws-sdk": "^2.859.0",
    "axios": "^1.3.4",
    "downloadjs": "^1.4.7",
    "esm": "^3.2.25",
    "netlify-lambda": "^1.6.3"
  }
